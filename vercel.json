{
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/styles.css", "destination": "/frontend/styles.css" },
    { "source": "/script.js", "destination": "/frontend/script.js" },
    { "source": "/property-check-guide.docx", "destination": "/frontend/property-check-guide.docx" },
    { "source": "/assets/:path*", "destination": "/frontend/assets/:path*" },
    { "source": "/about", "destination": "/frontend/about.html" },
    { "source": "/contact", "destination": "/frontend/contact.html" },
    { "source": "/insights", "destination": "/frontend/insights.html" },
    { "source": "/process", "destination": "/frontend/process.html" },
    { "source": "/privacy-policy", "destination": "/frontend/privacy-policy.html" },
    { "source": "/service-area", "destination": "/frontend/service-area.html" },
    { "source": "/services", "destination": "/frontend/services.html" },
    { "source": "/login", "destination": "/frontend/login.html" },
    { "source": "/signup", "destination": "/frontend/signup.html" },
    { "source": "/manifest.json", "destination": "/frontend/manifest.json" },
    { "source": "/sw.js", "destination": "/frontend/sw.js" },
    { "source": "/offline.html", "destination": "/frontend/offline.html" },
    { "source": "/404", "destination": "/frontend/404.html" },
    { "source": "/(.*)", "destination": "/frontend/404.html" }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/about.html", "destination": "/about", "permanent": true },
    { "source": "/contact.html", "destination": "/contact", "permanent": true },
    { "source": "/insights.html", "destination": "/insights", "permanent": true },
    { "source": "/process.html", "destination": "/process", "permanent": true },
    { "source": "/privacy-policy.html", "destination": "/privacy-policy", "permanent": true },
    { "source": "/service-area.html", "destination": "/service-area", "permanent": true },
    { "source": "/services.html", "destination": "/services", "permanent": true },
    { "source": "/login.html", "destination": "/login", "permanent": true },
    { "source": "/signup.html", "destination": "/signup", "permanent": true }
  ]
}
