{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/tos", "destination": "/tos.html" },
    { "source": "/portfolio", "destination": "/portfolio.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
